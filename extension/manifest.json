{
  "manifest_version": 3,
  "name": "BTF Setter OS — LinkedIn Co-Pilot",
  "version": "1.1.3",
  "description": "Scrapes LinkedIn conversations and profiles into BTF Setter OS for AI-powered reply, follow-up, and VN script generation.",

  "permissions": ["storage", "activeTab", "scripting", "sidePanel", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.lovable.app/*",
    "https://*.lovableproject.com/*",
    "http://localhost/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.lovable.app/*",
        "https://*.lovableproject.com/*",
        "http://localhost/*"
      ],
      "js": ["app-bridge.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
